#!/usr/bin/env python3
"""Hyprland Monitor Manager — KDE-style display configuration for Hyprland."""

import gi
gi.require_version("Gtk", "4.0")
gi.require_version("Adw", "1")
from gi.repository import Gtk, Adw, Gdk, GLib

import cairo
import json
import math
import os
import re
import subprocess

MONITORS_CONF = os.path.expanduser("~/.config/hypr/monitors.conf")
CANVAS_PADDING = 50
CANVAS_SCALE = 0.10

TRANSFORM_LABELS = [
    "Normal (0°)",
    "90° Horário",
    "180°",
    "270° Horário",
    "Espelhado",
    "Espelhado + 90°",
    "Espelhado + 180°",
    "Espelhado + 270°",
]

MONITOR_COLORS = [
    (0.25, 0.55, 0.95),
    (0.18, 0.78, 0.55),
    (0.95, 0.50, 0.15),
    (0.75, 0.28, 0.85),
    (0.95, 0.28, 0.35),
]


# ── Helpers ───────────────────────────────────────────────────────────────────

def get_monitors():
    try:
        r = subprocess.run(
            ["hyprctl", "monitors", "all", "-j"],
            capture_output=True, text=True, check=True,
        )
        return json.loads(r.stdout)
    except Exception:
        return []


def screen_dims(mon):
    """Return (screen_w, screen_h) — dimensions as they appear on screen."""
    w, h = mon["width"], mon["height"]
    if mon.get("transform", 0) in (1, 3, 5, 7):
        return h, w
    return w, h


def parse_modes(available_modes):
    """Return dict {(phys_w, phys_h): sorted([refresh, ...])} from availableModes."""
    result: dict[tuple, list] = {}
    for mode in available_modes:
        m = re.match(r"(\d+)x(\d+)@([\d.]+)", mode)
        if m:
            w, h, r = int(m.group(1)), int(m.group(2)), float(m.group(3))
            key = (w, h)
            if key not in result:
                result[key] = []
            if r not in result[key]:
                result[key].append(r)
    for key in result:
        result[key].sort(reverse=True)
    return result


def conf_line(mon):
    """Build a monitors.conf line for this monitor dict."""
    name = mon["name"]
    if mon.get("disabled", False):
        return f"monitor = {name}, disable"
    w, h = mon["width"], mon["height"]
    r = mon["refreshRate"]
    x, y = mon["x"], mon["y"]
    s = mon.get("scale", 1.0)
    t = mon.get("transform", 0)
    line = f"monitor = {name}, {w}x{h}@{r:.2f}, {x}x{y}, {s:g}"
    if t != 0:
        line += f", transform, {t}"
    return line


def apply_monitors(monitors):
    for mon in monitors:
        val = conf_line(mon).split(" = ", 1)[1]
        subprocess.run(["hyprctl", "keyword", "monitor", val],
                       capture_output=True)


def save_monitors(monitors):
    lines = ["# Generated by hypr-monitor-manager\n", "\n"]
    for mon in monitors:
        lines.append(conf_line(mon) + "\n")
    with open(MONITORS_CONF, "w") as f:
        f.writelines(lines)


# ── Canvas ────────────────────────────────────────────────────────────────────

class MonitorCanvas(Gtk.DrawingArea):
    def __init__(self, window):
        super().__init__()
        self.win = window
        self.monitors: list[dict] = []
        self.selected: int = -1
        self._drag_origin: tuple | None = None   # (mon_x, mon_y)
        self._canvas_ox = CANVAS_PADDING
        self._canvas_oy = CANVAS_PADDING

        self.set_draw_func(self._draw)
        self.set_can_focus(True)
        self.set_focusable(True)
        self.set_vexpand(True)
        self.set_hexpand(True)

        click = Gtk.GestureClick()
        click.connect("pressed", self._on_click)
        self.add_controller(click)

        drag = Gtk.GestureDrag()
        drag.connect("drag-begin", self._on_drag_begin)
        drag.connect("drag-update", self._on_drag_update)
        drag.connect("drag-end", self._on_drag_end)
        self.add_controller(drag)

    # ── public ──────────────────────────────────────────────────────────────

    def load(self, monitors):
        self.monitors = monitors
        self.selected = -1
        self._update_offset()
        self.queue_draw()

    def refresh_draw(self):
        self._update_offset()
        self.queue_draw()

    # ── geometry ────────────────────────────────────────────────────────────

    def _update_offset(self):
        if not self.monitors:
            self._canvas_ox = self._canvas_oy = CANVAS_PADDING
            return
        min_x = min(m["x"] for m in self.monitors)
        min_y = min(m["y"] for m in self.monitors)
        self._canvas_ox = CANVAS_PADDING - min_x * CANVAS_SCALE
        self._canvas_oy = CANVAS_PADDING - min_y * CANVAS_SCALE

    def _rect(self, mon):
        """Canvas rect (cx, cy, cw, ch) for a monitor."""
        sw, sh = screen_dims(mon)
        cx = mon["x"] * CANVAS_SCALE + self._canvas_ox
        cy = mon["y"] * CANVAS_SCALE + self._canvas_oy
        return cx, cy, sw * CANVAS_SCALE, sh * CANVAS_SCALE

    def _hit(self, px, py):
        for i, m in enumerate(self.monitors):
            cx, cy, cw, ch = self._rect(m)
            if cx <= px <= cx + cw and cy <= py <= cy + ch:
                return i
        return -1

    # ── drawing ─────────────────────────────────────────────────────────────

    def _draw(self, _area, cr, width, height):
        # Background
        cr.set_source_rgb(0.11, 0.11, 0.13)
        cr.rectangle(0, 0, width, height)
        cr.fill()

        # Grid
        cr.set_source_rgba(1, 1, 1, 0.04)
        cr.set_line_width(1)
        for x in range(0, width, 40):
            cr.move_to(x, 0); cr.line_to(x, height); cr.stroke()
        for y in range(0, height, 40):
            cr.move_to(0, y); cr.line_to(width, y); cr.stroke()

        if not self.monitors:
            cr.set_source_rgba(1, 1, 1, 0.4)
            cr.set_font_size(16)
            cr.move_to(width / 2 - 90, height / 2)
            cr.show_text("Nenhum monitor detectado")
            return

        for i, mon in enumerate(self.monitors):
            self._draw_monitor(cr, i, mon)

    def _draw_monitor(self, cr, idx, mon):
        cx, cy, cw, ch = self._rect(mon)
        color = MONITOR_COLORS[idx % len(MONITOR_COLORS)]
        disabled = mon.get("disabled", False)
        selected = (idx == self.selected)

        # Shadow
        cr.set_source_rgba(0, 0, 0, 0.35)
        cr.rectangle(cx + 5, cy + 5, cw, ch)
        cr.fill()

        # Fill
        r, g, b = color
        if disabled:
            cr.set_source_rgba(0.25, 0.25, 0.25, 0.9)
        else:
            cr.set_source_rgba(r * 0.22, g * 0.22, b * 0.22, 0.95)
        cr.rectangle(cx, cy, cw, ch)
        cr.fill()

        # Subtle gradient overlay
        if not disabled:
            lg = cairo.LinearGradient(cx, cy, cx, cy + ch)
            lg.add_color_stop_rgba(0, 1, 1, 1, 0.06)
            lg.add_color_stop_rgba(1, 0, 0, 0, 0.00)
            cr.set_source(lg)
            cr.rectangle(cx, cy, cw, ch)
            cr.fill()

        # Border
        if selected:
            cr.set_source_rgb(1, 1, 1)
            cr.set_line_width(2.5)
        else:
            cr.set_source_rgb(r * 0.8, g * 0.8, b * 0.8)
            cr.set_line_width(1.5)
        cr.rectangle(cx, cy, cw, ch)
        cr.stroke()

        # Labels
        cr.set_source_rgb(1, 1, 1)
        name = mon["name"]
        sw, sh = screen_dims(mon)
        res_text = f"{sw}×{sh}"
        hz_text = f"{mon['refreshRate']:.0f} Hz"
        lines = [name, res_text, hz_text]
        if disabled:
            lines.append("(desativado)")

        fs = max(9, min(13, ch / (len(lines) + 1)))
        cr.set_font_size(fs)
        lh = fs * 1.5
        total_h = len(lines) * lh
        start_y = cy + (ch - total_h) / 2 + fs

        for j, txt in enumerate(lines):
            ext = cr.text_extents(txt)
            cr.move_to(cx + (cw - ext.width) / 2, start_y + j * lh)
            if j == 0:
                cr.set_font_size(fs)
                cr.set_source_rgba(1, 1, 1, 1.0)
            else:
                cr.set_font_size(fs * 0.9)
                cr.set_source_rgba(1, 1, 1, 0.75)
            cr.show_text(txt)

        # Index badge
        cr.set_font_size(9)
        cr.set_source_rgba(1, 1, 1, 0.45)
        cr.move_to(cx + 5, cy + 12)
        cr.show_text(str(idx + 1))

    # ── events ──────────────────────────────────────────────────────────────

    def _on_click(self, _g, _n, x, y):
        idx = self._hit(x, y)
        if idx != self.selected:
            self.selected = idx
            self.queue_draw()
            self.win.on_monitor_selected(idx)

    def _on_drag_begin(self, _g, x, y):
        idx = self._hit(x, y)
        if idx >= 0:
            self.selected = idx
            m = self.monitors[idx]
            self._drag_origin = (m["x"], m["y"])
            self.queue_draw()
            self.win.on_monitor_selected(idx)
        else:
            self._drag_origin = None

    def _on_drag_update(self, _g, dx, dy):
        if self.selected < 0 or self._drag_origin is None:
            return
        mon = self.monitors[self.selected]
        nx = self._drag_origin[0] + dx / CANVAS_SCALE
        ny = self._drag_origin[1] + dy / CANVAS_SCALE
        nx, ny = self._snap(self.selected, nx, ny)
        mon["x"], mon["y"] = int(nx), int(ny)
        self._update_offset()
        self.queue_draw()
        self.win.settings.sync_position()

    def _on_drag_end(self, _g, _dx, _dy):
        # Final hard snap — close any remaining small gaps
        if self.selected >= 0:
            mon = self.monitors[self.selected]
            nx, ny = self._snap(self.selected, mon["x"], mon["y"],
                                dist=80 / CANVAS_SCALE)
            mon["x"], mon["y"] = int(nx), int(ny)
            self._update_offset()
            self.queue_draw()
            self.win.settings.sync_position()
        self._drag_origin = None

    def _snap(self, idx, nx, ny, dist=None):
        """Snap in monitor-pixel coords. dist defaults to 30 canvas-px equivalent."""
        if dist is None:
            dist = 30 / CANVAS_SCALE
        mon = self.monitors[idx]
        sw, sh = screen_dims(mon)
        bx, by = nx, ny
        for i, other in enumerate(self.monitors):
            if i == idx:
                continue
            ow, oh = screen_dims(other)
            ox, oy = other["x"], other["y"]
            # Snap right edge of dragged to left edge of other (and vice-versa)
            for ex in (ox - sw, ox + ow):
                if abs(nx - ex) < dist:
                    bx = ex
            for ey in (oy - sh, oy + oh):
                if abs(ny - ey) < dist:
                    by = ey
        return bx, by


# ── Settings Panel ────────────────────────────────────────────────────────────

class SettingsPanel(Gtk.Box):
    def __init__(self, win):
        super().__init__(orientation=Gtk.Orientation.VERTICAL)
        self.win = win
        self.monitor: dict | None = None
        self._loading = False
        self._modes: dict = {}
        self._sorted_res: list = []
        self._cur_rates: list = []

        self.set_size_request(310, -1)

        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scroll.set_vexpand(True)
        self.append(scroll)

        self._box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        self._box.set_margin_start(16)
        self._box.set_margin_end(16)
        self._box.set_margin_top(16)
        self._box.set_margin_bottom(16)
        scroll.set_child(self._box)
        self._build()
        self._show_empty()

    # ── build ────────────────────────────────────────────────────────────────

    def _build(self):
        b = self._box

        # Title
        self._title = Gtk.Label()
        self._title.set_markup("<b>Selecione um monitor</b>")
        self._title.set_halign(Gtk.Align.START)
        self._title.set_wrap(True)
        b.append(self._title)

        self._subtitle = Gtk.Label()
        self._subtitle.set_halign(Gtk.Align.START)
        self._subtitle.set_wrap(True)
        self._subtitle.add_css_class("dim-label")
        b.append(self._subtitle)

        b.append(Gtk.Separator())

        # Enable / disable
        row = Gtk.Box(spacing=8)
        lbl = Gtk.Label(label="Ativado")
        lbl.set_hexpand(True)
        lbl.set_halign(Gtk.Align.START)
        self._enable = Gtk.Switch()
        self._enable.connect("notify::active", self._on_enable)
        row.append(lbl)
        row.append(self._enable)
        b.append(row)

        b.append(Gtk.Separator())

        # Resolution
        self._add_heading("Resolução")
        self._res_combo = Gtk.DropDown()
        self._res_combo.set_hexpand(True)
        self._res_combo.connect("notify::selected", self._on_res)
        b.append(self._res_combo)

        # Refresh rate
        self._add_heading("Taxa de atualização")
        self._hz_combo = Gtk.DropDown()
        self._hz_combo.set_hexpand(True)
        self._hz_combo.connect("notify::selected", self._on_hz)
        b.append(self._hz_combo)

        b.append(Gtk.Separator())

        # Rotation
        self._add_heading("Rotação")
        rot_model = Gtk.StringList()
        for lbl_t in TRANSFORM_LABELS:
            rot_model.append(lbl_t)
        self._rot_combo = Gtk.DropDown(model=rot_model)
        self._rot_combo.set_hexpand(True)
        self._rot_combo.connect("notify::selected", self._on_rot)
        b.append(self._rot_combo)

        b.append(Gtk.Separator())

        # Scale
        self._add_heading("Escala")
        scale_box = Gtk.Box(spacing=8)
        adj = Gtk.Adjustment(value=1.0, lower=0.25, upper=4.0,
                             step_increment=0.25, page_increment=0.5)
        self._scale_spin = Gtk.SpinButton(adjustment=adj, digits=2)
        self._scale_spin.set_hexpand(True)
        self._scale_spin.connect("value-changed", self._on_scale)
        scale_box.append(self._scale_spin)
        b.append(scale_box)

        b.append(Gtk.Separator())

        # Position
        self._add_heading("Posição")
        grid = Gtk.Grid()
        grid.set_column_spacing(8)
        grid.set_row_spacing(4)

        grid.attach(Gtk.Label(label="X:"), 0, 0, 1, 1)
        adj_x = Gtk.Adjustment(value=0, lower=-20000, upper=20000,
                               step_increment=1, page_increment=10)
        self._pos_x = Gtk.SpinButton(adjustment=adj_x)
        self._pos_x.set_hexpand(True)
        self._pos_x.connect("value-changed", self._on_pos)
        grid.attach(self._pos_x, 1, 0, 1, 1)

        grid.attach(Gtk.Label(label="Y:"), 0, 1, 1, 1)
        adj_y = Gtk.Adjustment(value=0, lower=-20000, upper=20000,
                               step_increment=1, page_increment=10)
        self._pos_y = Gtk.SpinButton(adjustment=adj_y)
        self._pos_y.set_hexpand(True)
        self._pos_y.connect("value-changed", self._on_pos)
        grid.attach(self._pos_y, 1, 1, 1, 1)

        b.append(grid)

    def _add_heading(self, text):
        lbl = Gtk.Label(label=text)
        lbl.set_halign(Gtk.Align.START)
        lbl.add_css_class("heading")
        self._box.append(lbl)

    # ── public ───────────────────────────────────────────────────────────────

    def _show_empty(self):
        self.monitor = None
        self._title.set_markup("<b>Selecione um monitor</b>")
        self._subtitle.set_text("Clique em um monitor acima para configurá-lo.")

    def load(self, mon: dict):
        self.monitor = mon
        self._loading = True

        name = mon.get("name", "?")
        desc = mon.get("description") or f"{mon.get('make','')} {mon.get('model','')}".strip()
        self._title.set_markup(f"<b>{name}</b>")
        self._subtitle.set_text(desc)

        self._enable.set_active(not mon.get("disabled", False))

        # Modes
        self._modes = parse_modes(mon.get("availableModes", []))
        self._sorted_res = sorted(self._modes.keys(),
                                  key=lambda k: k[0] * k[1], reverse=True)
        res_model = Gtk.StringList()
        for w, h in self._sorted_res:
            res_model.append(f"{w}×{h}")
        self._res_combo.set_model(res_model)

        # Current physical resolution
        cur_w, cur_h = mon["width"], mon["height"]
        sel_r = 0
        for i, (w, h) in enumerate(self._sorted_res):
            if w == cur_w and h == cur_h:
                sel_r = i
                break
        self._res_combo.set_selected(sel_r)
        self._fill_hz(sel_r, mon.get("refreshRate", 60))

        self._rot_combo.set_selected(mon.get("transform", 0))
        self._scale_spin.set_value(mon.get("scale", 1.0))
        self._pos_x.set_value(mon.get("x", 0))
        self._pos_y.set_value(mon.get("y", 0))

        self._loading = False

    def sync_position(self):
        """Called when canvas drag updates position."""
        if not self.monitor:
            return
        self._loading = True
        self._pos_x.set_value(self.monitor.get("x", 0))
        self._pos_y.set_value(self.monitor.get("y", 0))
        self._loading = False

    # ── private helpers ──────────────────────────────────────────────────────

    def _fill_hz(self, res_idx, current_hz=None):
        if not self._sorted_res or res_idx >= len(self._sorted_res):
            return
        key = self._sorted_res[res_idx]
        rates = self._modes.get(key, [])
        self._cur_rates = rates

        hz_model = Gtk.StringList()
        for r in rates:
            hz_model.append(f"{r:.2f} Hz")
        self._hz_combo.set_model(hz_model)

        sel = 0
        if current_hz:
            for i, r in enumerate(rates):
                if abs(r - current_hz) < 0.5:
                    sel = i
                    break
        self._hz_combo.set_selected(sel)

    # ── change handlers ──────────────────────────────────────────────────────

    def _on_enable(self, sw, _p):
        if self._loading or not self.monitor:
            return
        self.monitor["disabled"] = not sw.get_active()
        self.win.canvas.queue_draw()

    def _on_res(self, combo, _p):
        if self._loading or not self.monitor:
            return
        idx = combo.get_selected()
        if idx >= len(self._sorted_res):
            return
        phys_w, phys_h = self._sorted_res[idx]
        # Store physical dimensions — canvas uses screen_dims() to display
        self.monitor["width"] = phys_w
        self.monitor["height"] = phys_h
        self._fill_hz(idx)
        self.win.canvas.refresh_draw()

    def _on_hz(self, combo, _p):
        if self._loading or not self.monitor:
            return
        idx = combo.get_selected()
        if idx < len(self._cur_rates):
            self.monitor["refreshRate"] = self._cur_rates[idx]

    def _on_rot(self, combo, _p):
        if self._loading or not self.monitor:
            return
        self.monitor["transform"] = combo.get_selected()
        self.win.canvas.refresh_draw()

    def _on_scale(self, spin):
        if self._loading or not self.monitor:
            return
        self.monitor["scale"] = spin.get_value()

    def _on_pos(self, _spin):
        if self._loading or not self.monitor:
            return
        self.monitor["x"] = int(self._pos_x.get_value())
        self.monitor["y"] = int(self._pos_y.get_value())
        self.win.canvas.refresh_draw()


# ── Main Window ───────────────────────────────────────────────────────────────

class MonitorManagerWindow(Adw.ApplicationWindow):
    def __init__(self, app):
        super().__init__(application=app)
        self.monitors: list[dict] = []
        self.set_title("Monitor Manager")
        self.set_default_size(1100, 680)
        self._build()
        self.load_monitors()

    def _build(self):
        # Toast overlay wraps everything
        self._toast_overlay = Adw.ToastOverlay()
        self.set_content(self._toast_overlay)

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self._toast_overlay.set_child(outer)

        # Header
        hdr = Adw.HeaderBar()
        hdr.set_title_widget(
            Adw.WindowTitle(
                title="Monitor Manager",
                subtitle="Configuração de Displays — Hyprland",
            )
        )

        reload_btn = Gtk.Button()
        reload_btn.set_icon_name("view-refresh-symbolic")
        reload_btn.set_tooltip_text("Recarregar monitores")
        reload_btn.connect("clicked", lambda _: self.load_monitors())
        hdr.pack_start(reload_btn)

        self._save_btn = Gtk.Button(label="Salvar")
        self._save_btn.set_tooltip_text(f"Salvar em {MONITORS_CONF}")
        self._save_btn.connect("clicked", self._on_save)
        hdr.pack_end(self._save_btn)

        self._apply_btn = Gtk.Button(label="Aplicar")
        self._apply_btn.add_css_class("suggested-action")
        self._apply_btn.set_tooltip_text("Aplicar sem salvar arquivo")
        self._apply_btn.connect("clicked", self._on_apply)
        hdr.pack_end(self._apply_btn)

        outer.append(hdr)

        # Body — paned: canvas | settings
        paned = Gtk.Paned(orientation=Gtk.Orientation.HORIZONTAL)
        paned.set_vexpand(True)
        outer.append(paned)

        frame = Gtk.Frame()
        self.canvas = MonitorCanvas(self)
        frame.set_child(self.canvas)
        paned.set_start_child(frame)
        paned.set_resize_start_child(True)

        self.settings = SettingsPanel(self)
        paned.set_end_child(self.settings)
        paned.set_resize_end_child(False)
        paned.set_position(760)

    # ── public callbacks ─────────────────────────────────────────────────────

    def load_monitors(self):
        self.monitors = get_monitors()
        self.canvas.load(self.monitors)
        self.settings._show_empty()

    def on_monitor_selected(self, idx):
        if 0 <= idx < len(self.monitors):
            self.settings.load(self.monitors[idx])
        else:
            self.settings._show_empty()

    # ── actions ──────────────────────────────────────────────────────────────

    def _on_apply(self, _btn):
        try:
            apply_monitors(self.monitors)
            self._toast("Configuração aplicada com sucesso!")
        except Exception as e:
            self._toast(f"Erro ao aplicar: {e}")

    def _on_save(self, _btn):
        try:
            save_monitors(self.monitors)
            self._toast(f"Salvo em {MONITORS_CONF}")
        except Exception as e:
            self._toast(f"Erro ao salvar: {e}")

    def _toast(self, msg):
        self._toast_overlay.add_toast(Adw.Toast(title=msg))


# ── App ───────────────────────────────────────────────────────────────────────

class MonitorManagerApp(Adw.Application):
    def __init__(self):
        super().__init__(application_id="io.github.hypr-monitor-manager")
        self.connect("activate", self._on_activate)

    def _on_activate(self, _app):
        win = MonitorManagerWindow(self)
        win.present()


if __name__ == "__main__":
    import sys
    app = MonitorManagerApp()
    sys.exit(app.run(sys.argv))
